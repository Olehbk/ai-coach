ANTHROPIC_API_KEY=

# ── Email / SMTP ───────────────────────────────────────────────────────────
# Works with any standard SMTP provider. Examples:
#
#   Gmail:    SMTP_HOST=smtp.gmail.com     SMTP_PORT=587
#             SMTP_PASS = 16-char App Password (NOT your login password)
#             Generate at: Google Account → Security → App Passwords
#
#   Outlook:  SMTP_HOST=smtp.office365.com SMTP_PORT=587
#   iCloud:   SMTP_HOST=smtp.mail.me.com   SMTP_PORT=587
#   Custom:   use whatever your mail server provides
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

PORT=3000

SCHEDULE_CRON="* * * * *"

# ── Scheduler ──────────────────────────────────────────────────────────────
# Default: every Sunday at 08:00. Override for testing:
#   Every minute  → SCHEDULE_CRON="* * * * *"
#   In 1 min test → set to the next minute, e.g. "45 14 * * *"
# SCHEDULE_CRON="0 8 * * 0"
